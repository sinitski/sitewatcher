# Database
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/sitewatcher
# For local SQLite: sqlite+aiosqlite:///./sitewatcher.db

# Auth
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAF...

# App
FRONTEND_URL=http://localhost:5173
ENV=development
# Set ENV=production to hide /docs

# Payments
ADMIN_SECRET=change-me-to-a-random-string
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_SUCCESS_URL=https://sitewatcher-six.vercel.app/upgrade?paypal=success
PAYPAL_CANCEL_URL=https://sitewatcher-six.vercel.app/upgrade?paypal=cancel

# Limits
FREE_TIER_MAX_SITES=1
FREE_TIER_MIN_INTERVAL=60
PAID_TIER_MAX_SITES=50
PAID_TIER_MIN_INTERVAL=1
